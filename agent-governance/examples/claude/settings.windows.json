{
  "env": {
    "AGENT_HOOK_ENDOR_API": "https://api.endorlabs.com",
    "AGENT_HOOK_ENDOR_API_CREDENTIALS_KEY": "PEPE",
    "AGENT_HOOK_ENDOR_API_CREDENTIALS_SECRET": "PAPA",
    "AGENT_HOOK_ENDOR_NAMESPACE": "spiderman",
    "ENDOR_AI_AUDIT_CACHE_ENABLED": "true"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -EncodedCommand "
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -EncodedCommand "
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -EncodedCommand "
          }
        ],
        "matcher": ".*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -EncodedCommand "
          }
        ],
        "matcher": ".*"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -EncodedCommand "
          }
        ],
        "matcher": ".*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -EncodedCommand "
          }
        ]
      }
    ]
  }
}
